{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jhashikhar/digital-signal-governance/blob/main/glossary/glossary.schema.json",

  "title": "Digital Signal Governance Glossary Schema",

  "description": "JSON Schema for validating glossary entries in the Digital Signal Governance public conceptual framework repository.",

  "type": "object",

  "required": [
    "framework",
    "version",
    "canonical",
    "maintainer",
    "license",
    "terms"
  ],

  "properties": {
    "framework": {
      "type": "string"
    },

    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },

    "canonical": {
      "type": "boolean"
    },

    "license": {
      "type": "string"
    },

    "maintainer": {
      "type": "object",

      "required": [
        "name",
        "organization",
        "repository",
        "orcid"
      ],

      "properties": {
        "name": {
          "type": "string"
        },

        "organization": {
          "type": "string"
        },

        "repository": {
          "type": "string",
          "format": "uri"
        },

        "orcid": {
          "type": "string",
          "format": "uri"
        }
      },

      "additionalProperties": false
    },

    "terms": {
      "type": "array",
      "minItems": 1,

      "items": {
        "$ref": "#/$defs/GlossaryTerm"
      }
    }
  },

  "additionalProperties": false,

  "$defs": {
    "GlossaryTerm": {
      "type": "object",

      "required": [
        "id",
        "term",
        "definition",
        "governance_relevance",
        "category",
        "related_terms",
        "type"
      ],

      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },

        "term": {
          "type": "string"
        },

        "definition": {
          "type": "string",
          "minLength": 30,
          "maxLength": 600
        },

        "governance_relevance": {
          "type": "string",
          "minLength": 30,
          "maxLength": 600
        },

        "category": {
          "type": "string",
          "enum": [
            "signal-governance",
            "identity-governance",
            "consent-governance",
            "measurement-governance",
            "governance-risk",
            "adjacent-framework"
          ]
        },

        "related_terms": {
          "type": "array",

          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },

          "minItems": 0,
          "maxItems": 10
        },

        "type": {
          "type": "string",
          "enum": [
            "core",
            "relational"
          ]
        },

        "note": {
          "type": "string"
        },

        "deprecated": {
          "type": "boolean"
        },

        "superseded_by": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      },

      "additionalProperties": false
    }
  }
}
